Format untuk semua pengisian post
{
  "nim": "",
  "nama": "",
  "prodi": "",
  "bahasa": 1-5,
  "jenis": 1-5
}

{
  "userId": "64f1c2a9b1a3c9a123456789",
  "nim": "535259991",
  "nama": "Rizki Rafael",
  "prodi": "Informatika",
  "bahasa": 1,
  "jenis": 1
}

